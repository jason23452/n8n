MCP_PORT=5679
MCP_MODE=development
# API token for agents to register/use the MCP server
MCP_API_TOKEN=changeme_replace_with_real_token
# URL where n8n or other agents can reach the MCP server
MCP_EXTERNAL_URL=http://localhost:5679
# Log level: debug, info, warn, error
MCP_LOG_LEVEL=info

# Storage (file-based) settings
MCP_STORAGE_PATH=/data

# Optional: TLS settings (for production)
#MCP_TLS_CERT=/data/tls/fullchain.pem
#MCP_TLS_KEY=/data/tls/privkey.pem

# NOTE: Copy this file to .env and replace secrets before starting
